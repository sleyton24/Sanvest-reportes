# Plantilla de configuración — copiar a `.env` y completar (NO commitear `.env`).
#
# El proyecto es agnóstico de motor (SQLAlchemy). Sin estas variables usa el SQLite
# de desarrollo (db/sanvest_bi_dev.sqlite). En PRODUCCIÓN apunta al PostgreSQL del
# VPS (base 'sanvest') y la API + el ETL escriben/leen ahí.
#
# Se usan variables separadas (no una URL) porque el usuario/clave pueden traer
# caracteres como @ o $ que romperían una URL.

PGHOST=tu.host.o.ip
PGPORT=5432
PGUSER=usuario
PGPASSWORD=clave
PGDATABASE=sanvest

# Si el servidor exige TLS:
# PGSSLMODE=require

# Alternativa: una sola URL (solo si user/clave no tienen caracteres especiales)
# SANVEST_DB_URL=postgresql+psycopg2://usuario:clave@host:5432/sanvest

# ----------------------------- Seguridad (producción) ------------------------
# Marca el entorno como producción: oculta /docs, /redoc y /openapi.json.
SANVEST_ENV=prod
# Token compartido para los endpoints que ESCRIBEN o GASTAN (/upload,
# /upload-informes, /ask). Si está definido, esas rutas exigen el header
# 'X-API-Token: <token>' (o 'Authorization: Bearer <token>'). Generar aleatorio:
#   python -c "import secrets;print(secrets.token_urlsafe(32))"
# Debe coincidir con VITE_API_TOKEN usado al construir el frontend (npm run build).
SANVEST_API_TOKEN=pon-un-token-largo-aleatorio
# Agente Claude: apagado por defecto (endpoint /ask -> 503). Encender SOLO cuando
# exista UI de chat + rate-limit, y con ANTHROPIC_API_KEY definido.
# SANVEST_ASK_ENABLED=1
# ANTHROPIC_API_KEY=sk-ant-...
# Mantenedor de ETL (F4, Admin > Mantener ETL): agente que ajusta los specs del ETL
# con validación dura; el spec se aplica a prod solo con aprobación humana (/etl/apply).
# Apagado por defecto (/etl/ask -> 503). Requiere ANTHROPIC_API_KEY.
# SANVEST_ETL_AGENT_ENABLED=1

# ----------------------------- Login por usuario (perfilado) -----------------
# Secreto para firmar los tokens de sesión (JWT HMAC). OBLIGATORIO en prod.
# Generar: python -c "import secrets;print(secrets.token_urlsafe(48))"
SANVEST_AUTH_SECRET=pon-un-secreto-largo-aleatorio
# Duración del token en segundos (opcional; por defecto 12 h).
# SANVEST_AUTH_TTL=43200
# La tabla de usuarios (app_users) en prod la crea un DBA con db/ddl_app_users.sql
# (el usuario runtime no tiene privilegio CREATE). Crear usuarios:
#   python scripts/manage_users.py create --admin <usuario>

# NOTA: rotar PGPASSWORD por uno fuerte y aleatorio; NO dejar el .env en carpeta
# sincronizada a la nube; en el VPS va como EnvironmentFile de systemd con chmod 600.
